{
	"name": "backbrain",
	"type": "module",
	"version": "1.2.0",
	"description": "Backbrain (formerly flux-cap): keep a running memory of your work, searchable from the CLI and readable by your AI",
	"bin": {
		"bb": "./dist/index.js",
		"backbrain": "./dist/index.js",
		"flux": "./dist/index.js",
		"flux-mcp": "./dist/mcp-server.ts"
	},
	"files": [
		"dist/index.js",
		"dist/mcp-server.js",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target node --format esm && bun build src/mcp-server.ts --outdir dist --target node --format esm",
		"dev": "bun run src/index.ts",
		"prepublishOnly": "bun run build",
		"publish": "npm publish --access=public",
		"local-install": "bun run build && npm link",
		"local-uninstall": "npm unlink -g bb",
		"local-reinstall": "bun run local-uninstall && bun run local-install",
		"changeset": "changeset",
		"changeset:add": "changeset add",
		"changeset:status": "changeset status",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"format": "bunx --bun @biomejs/biome check --write"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"keywords": [
		"cli",
		"productivity",
		"git",
		"context-switching",
		"developer-journal",
		"developer-tools",
		"backbrain",
		"notes",
		"mcp",
		"command-line",
		"workflow",
		"memory",
		"search",
		"ai-tools",
		"developer-workflow",
		"code-context",
		"project-management",
		"task-tracking",
		"work-log",
		"searchable-notes",
		"terminal",
		"logbook",
		"logs",
		"development-tools"
	],
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.28.0",
		"commander": "^14.0.3",
		"fuse.js": "^7.1.0",
		"inquirer": "^13.2.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@changesets/cli": "^2.29.8",
		"@types/inquirer": "^9.0.9",
		"@types/node": "^25.3.3"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kaustubh285/backbrain"
	},
	"license": "MIT",
	"homepage": "backbrain.deshpande.page"
}
